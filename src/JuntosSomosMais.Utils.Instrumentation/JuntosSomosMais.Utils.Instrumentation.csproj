<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>JuntosSomosMais.Utils.Instrumentation</RootNamespace>
    <Description>Validation instrumentation for ASP.NET Core APIs and Ziggurat message pipelines.</Description>
    <PackageId>JuntosSomosMais.Utils.Instrumentation</PackageId>
    <PackageTags>validation instrumentation aspnetcore ziggurat middleware filter</PackageTags>
    <MinVerTagPrefix>instrumentation/v</MinVerTagPrefix>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="FluentValidation" Version="11.*" />
    <PackageReference Include="JuntosSomosMais.Ziggurat" Version="0.1.0-test.2" />
  </ItemGroup>
</Project>
